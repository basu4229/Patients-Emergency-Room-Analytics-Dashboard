Date = 
ADDCOLUMNS(
CALENDARAUTO(),
"Year", YEAR([Date]),
"Month",FORMAT([Date],"mmm"),
"WeekType" ,IF(WEEKDAY([Date])=1,"Weekend",IF(WEEKDAY([Date])=7,"Weekend","Weekday")),
"Weekday",FORMAT([Date],"ddd"),
"MonthNum",MONTH([Date])
)
